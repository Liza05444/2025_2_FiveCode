FROM golang:1.25-alpine AS builder
WORKDIR /app

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY pkg ./pkg
COPY user_service ./user_service

RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg/mod \
    CGO_ENABLED=0 go build -o /app/bin/user-service ./user_service/cmd/main.go

FROM alpine:latest
WORKDIR /app

COPY --from=builder /app/bin/user-service .
COPY config ./config/
COPY --from=builder /app/user_service/db/migrations ./db/migrations

EXPOSE 50052
CMD ["./user-service"]